PORT=3000

# MQTT
MQTT_BROKER_URL=mqtts://your-hivemq-host:8883
MQTT_TOPIC=katd/+/data
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password
MQTT_CLIENT_ID=katd-dashboard-ruang2

# InfluxDB v2
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your_influx_token
INFLUX_ORG=your_org
INFLUX_BUCKET=your_bucket
INFLUX_MEASUREMENT=sensor_data

# If true, incoming MQTT data is also written by this app into InfluxDB.
# Keep false if your pipeline already writes to InfluxDB.
WRITE_TO_INFLUX=false
